# ============================================================
# DalalStreet AI — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_ENV=development                  # development | production
APP_SECRET_KEY=your_secret_key_here  # Used for HMAC signing

# ── Upstox API ────────────────────────────────────────────────
UPSTOX_API_KEY=your_upstox_api_key
UPSTOX_API_SECRET=your_upstox_api_secret
UPSTOX_REDIRECT_URI=http://localhost:8000/api/v1/auth/upstox/callback
UPSTOX_ACCESS_TOKEN=                 # Set after OAuth flow

# ── Kite Connect (Zerodha) — fallback ─────────────────────────
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=                   # Set after OAuth flow

# ── Claude / Anthropic API ────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Database ──────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dalalstreet
POSTGRES_USER=dalalstreet_user
POSTGRES_PASSWORD=your_postgres_password
DATABASE_URL=postgresql+asyncpg://dalalstreet_user:your_postgres_password@localhost:5432/dalalstreet

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth ──────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60              # requests per window
RATE_LIMIT_WINDOW=60                # seconds

# ── Celery ────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Report Cache TTL ──────────────────────────────────────────
REPORT_CACHE_TTL_SECONDS=300        # 5 minutes
