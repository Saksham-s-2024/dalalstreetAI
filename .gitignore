# ============================================================
# DalalStreet AI — .gitignore
# ============================================================

# ── Environment & Secrets ─────────────────────────────────────
.env
.env.*
!.env.example
*.secret
secrets/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
venv/
.venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.cover
celerybeat-schedule

# ── Node / Next.js ────────────────────────────────────────────
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── ML / Data ─────────────────────────────────────────────────
*.pt
*.pth
*.onnx
*.pkl
*.h5
data/raw/
data/processed/
models/weights/

# ── Database ──────────────────────────────────────────────────
*.db
*.sqlite3
*.sql.gz

# ── IDE / OS ──────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Docker volumes ────────────────────────────────────────────
docker-data/
